# 复制到目标机 /etc/sub2api-vless-relay.env，权限设为 600。
# 不要把真实值提交到 Git。

VLESS_RELAY_UPSTREAM_URL=请填写上游订阅地址
VLESS_RELAY_PUBLIC_HOST=请填写新机公网IP或DNS_ONLY域名
VLESS_RELAY_SUB_PORT=24480
VLESS_RELAY_PORT_START=24443
VLESS_RELAY_PORT_COUNT=30
VLESS_RELAY_LOCAL_SOCKS_START=10808
VLESS_RELAY_SNI=www.microsoft.com

VLESS_RELAY_STATE_DIR=/home/ubuntu/sub2api/.dev/vless-relay
VLESS_RELAY_SING_BOX_DIR=/home/ubuntu/sub2api/.dev/sing-box
VLESS_RELAY_COMPOSE_DIR=/home/ubuntu/sub2api/deploy
VLESS_RELAY_SING_BOX_CONTAINER=sub2api-sing-box-vless
VLESS_RELAY_SUB_CONTAINER=sub2api-vless-relay-sub

VLESS_RELAY_REALITY_PRIVATE_KEY=请填写原私钥
VLESS_RELAY_REALITY_PUBLIC_KEY=请填写原公钥
